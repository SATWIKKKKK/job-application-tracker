{
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/gmail-catchup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/gmail-renew",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/check-expiry",
      "schedule": "30 3 * * *"
    }
  ]
}
